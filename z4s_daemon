#!/bin/bash
# Zspace Z4S - SATA Power, LED Control & Health Monitor
# LED values: 00=off  01=green  05=green-blink(IO)
#             08=red(fault)  09=yellow(degraded)  24=yellow-blink(rebuilding)
# Bay LED registers: port1=0x54(84) port2=0x53(83) port3=0x52(82) port4=0x51(81)

HAS_SMARTCTL=0
if command -v smartctl &>/dev/null; then
    HAS_SMARTCTL=1
else
    echo "[WARN] smartctl not found — SMART health check disabled. Install: apt install smartmontools" >&2
fi

HAS_ZPOOL=0
if command -v zpool &>/dev/null; then
    HAS_ZPOOL=1
else
    echo "[WARN] zpool not found — ZFS health check disabled. Install: apt install zfsutils-linux" >&2
fi

wait_ec() {
    local val
    while val=$(dd if=/dev/port bs=1 skip=102 count=1 status=none 2>/dev/null | od -An -tu1);
          (( val & 2 )); do
        sleep 0.005
    done
}

write_ec() {
    wait_ec; printf "\x81"  | dd of=/dev/port bs=1 seek=102 conv=notrunc status=none
    wait_ec; printf "\x$1"  | dd of=/dev/port bs=1 seek=98  conv=notrunc status=none
    wait_ec; printf "\x$2"  | dd of=/dev/port bs=1 seek=98  conv=notrunc status=none
}

port_reg() { printf "%02x" $(( 85 - $1 )); }

get_disk_map() {
    local disk path dev port tmp
    for disk in /sys/block/sata* /sys/block/sd*; do
        [ -d "$disk" ] || continue
        path=$(readlink "$disk") || continue
        [[ "$path" == *usb* ]] && continue
        dev="${disk##*/}"
        tmp="${path#*/ata}"
        port="${tmp%%/*}"
        [[ "$port" =~ ^[1-4]$ ]] && echo "${dev}:${port}"
    done
}

declare -gA _diskstats=()
refresh_diskstats() {
    local _ dev rc wc
    _diskstats=()
    while read -r _ _ dev rc _ _ _ wc _; do
        _diskstats["$dev"]=$(( rc + wc ))
    done < /proc/diskstats
}

get_io_count() {
    echo "${_diskstats[$1]:-0}"
}

check_disk_health() {
    local dev="$1" zpool_out="$2" mdstat="$3"

    local state_file="/sys/block/${dev}/device/state"
    if [ -f "$state_file" ]; then
        local state; state=$(< "$state_file")
        [[ "$state" != "running" && -n "$state" ]] && echo "fault" && return
    fi

    if (( HAS_SMARTCTL )); then
        timeout 3 smartctl -d sat -n standby -H "/dev/${dev}" &>/dev/null
        (( $? > 2 )) && echo "fault" && return
    fi

    if (( HAS_ZPOOL )) && [ -n "$zpool_out" ]; then
        local identifiers=("$dev") link target
        for dir in /dev/disk/by-id /dev/disk/by-partuuid /dev/disk/by-uuid; do
            [ -d "$dir" ] || continue
            for link in "$dir"/*; do
                [ -e "$link" ] || continue
                target=$(basename "$(readlink "$link" 2>/dev/null)")
                [[ "$target" == ${dev}* ]] && identifiers+=("$(basename "$link")")
            done
        done
        local match_line ident
        for ident in "${identifiers[@]}"; do
            match_line=$(grep -F "$ident" <<< "$zpool_out") || continue
            grep -qiE "resilvering"     <<< "$match_line" && echo "rebuilding" && return
            grep -qiE "FAULTED|UNAVAIL" <<< "$match_line" && echo "fault"      && return
            grep -qiE "DEGRADED"        <<< "$match_line" && echo "degraded"   && return
        done
    fi

    if [ -n "$mdstat" ] && grep -q "$dev" <<< "$mdstat"; then
        grep -qE "recovery|resync" <<< "$mdstat" && echo "rebuilding" && return
        grep -qE "\[.*_.*\]"       <<< "$mdstat" && echo "degraded"   && return
    fi

    echo "normal"
}

boot_drives() {
    write_ec "59" "0b"   # reg 0x59: power control
    write_ec "50" "01"   # reg 0x50: enable

    # Staggered spin-up: 5s delay per drive to prevent peak current overload
    local v
    for v in c0 f0 fc ff; do
        write_ec "58" "$v"
        sleep 5
    done
    sleep 3

    # Clear all bay LEDs (0x51–0x54)
    local p
    for p in 1 2 3 4; do write_ec "$(port_reg "$p")" "00"; done

    # Light up present drives
    local entry port
    for entry in $(get_disk_map); do
        port="${entry##*:}"
        write_ec "$(port_reg "$port")" "01"
    done
}

run_monitor() {
    local HEALTH_INTERVAL=60   # seconds between SMART/RAID checks
    local DISKMAP_INTERVAL=5   # seconds between disk map refresh
    local IO_BLINK_MS=80
    local last_health_check=0
    local last_diskmap_check=0
    local now need_health entry dev port reg health io_now io_prev target_hex
    declare -A health_cache io_last led_state
    local disk_entries=()

    while true; do
        now=$(date +%s)

        if (( now - last_diskmap_check >= DISKMAP_INTERVAL )); then
            mapfile -t disk_entries < <(get_disk_map)
            last_diskmap_check=$now
        fi

        declare -A present_devs=()
        for entry in "${disk_entries[@]}"; do
            present_devs["${entry%%:*}"]=1
        done

        for dev in "${!health_cache[@]}"; do
            [[ -z "${present_devs[$dev]}" ]] && unset "health_cache[$dev]" "io_last[$dev]"
        done

        need_health=0
        for entry in "${disk_entries[@]}"; do
            [[ -z "${health_cache[${entry%%:*}]}" ]] && need_health=1 && break
        done
        (( now - last_health_check >= HEALTH_INTERVAL )) && need_health=1

        if (( need_health )); then
            local zpool_out="" mdstat=""
            (( HAS_ZPOOL )) && zpool_out=$(timeout 3 zpool status 2>/dev/null)
            [ -f /proc/mdstat ] && mdstat=$(< /proc/mdstat)
            for entry in "${disk_entries[@]}"; do
                dev="${entry%%:*}"
                health_cache["$dev"]=$(check_disk_health "$dev" "$zpool_out" "$mdstat")
            done
            last_health_check=$now
        fi

        refresh_diskstats

        declare -A io_active_regs=()
        declare -A occupied_regs=()

        for entry in "${disk_entries[@]}"; do
            dev="${entry%%:*}"; port="${entry##*:}"
            reg=$(port_reg "$port")
            health="${health_cache[$dev]:-normal}"
            io_now=$(get_io_count "$dev")
            io_prev="${io_last[$dev]:-$io_now}"

            occupied_regs["$reg"]=1
            [[ "$health" == "normal" ]] && (( io_now != io_prev )) && io_active_regs["$reg"]=1
            io_last["$dev"]=$io_now

            case "$health" in
                fault)      target_hex="08" ;;
                degraded)   target_hex="09" ;;
                rebuilding) target_hex="24" ;;
                *)          target_hex="01" ;;
            esac

            if [[ "${led_state[$reg]}" != "$target_hex" && -z "${io_active_regs[$reg]}" ]]; then
                write_ec "$reg" "$target_hex"
                led_state["$reg"]="$target_hex"
            fi
        done

        if (( ${#io_active_regs[@]} > 0 )); then
            for reg in "${!io_active_regs[@]}"; do write_ec "$reg" "00"; done
            sleep "0.$(printf '%03d' "$IO_BLINK_MS")"
            for reg in "${!io_active_regs[@]}"; do
                write_ec "$reg" "05"
                led_state["$reg"]="05"
            done
        fi

        local p r
        for p in 1 2 3 4; do
            r=$(port_reg "$p")
            if [[ -z "${occupied_regs[$r]}" ]] && [[ "${led_state[$r]}" != "00" ]]; then
                write_ec "$r" "00"
                led_state["$r"]="00"
            fi
        done

        sleep 0.2
    done
}

case "${1:-boot}" in
    boot)
        boot_drives
        ;;
    monitor)
        run_monitor
        ;;
    boot-monitor)
        boot_drives
        sleep 1
        run_monitor
        ;;
    status)
        _zpool_out=""
        _mdstat=""
        (( HAS_ZPOOL )) && _zpool_out=$(timeout 3 zpool status 2>/dev/null)
        [ -f /proc/mdstat ] && _mdstat=$(< /proc/mdstat)
        refresh_diskstats
        for entry in $(get_disk_map); do
            dev="${entry%%:*}"; port="${entry##*:}"
            printf "/dev/%-4s  port%s  reg=0x%s  health=%-10s  io=%s\n" \
                "$dev" "$port" "$(port_reg "$port")" \
                "$(check_disk_health "$dev" "$_zpool_out" "$_mdstat")" \
                "$(get_io_count "$dev")"
        done
        ;;
    *)
        echo "Usage: $0 {boot|monitor|boot-monitor|status}"
        exit 1
        ;;
esac
